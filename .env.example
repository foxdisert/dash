# Path to the SQLite database file
DATABASE_PATH=./data/morsardash.db

# 32-byte key (base64 or hex) used to encrypt provider API keys at rest (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# Secret used to sign the admin session JWT.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# Initial admin password (used once by `npm run seed` to create the admin account).
ADMIN_PASSWORD=changeme

# ---- Notifications ----
# Alert when a client is this many days (or fewer) from expiry. Default 2.
NOTIFY_DAYS=2

# Telegram alerts (optional). Create a bot via @BotFather for the token.
# Get your chat id by messaging @userinfobot, or from getUpdates after texting your bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Shared secret protecting the cron endpoint /api/cron/check-expiring.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=

# ---- Email (SMTP) ----
# Optional: these are fallbacks. Primary config is in the dashboard Settings page.
# Recommended provider: Brevo (smtp-relay.brevo.com:587). The "from" address must be
# a verified sender/domain. SMTP_PASS is your Brevo SMTP key (Master Password).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=
EMAIL_FROM_ADDRESS=

# ---- Website orders webhook ----
# Shared secret protecting POST /api/orders/incoming (your WordPress snippet sends it).
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ORDERS_WEBHOOK_SECRET=
